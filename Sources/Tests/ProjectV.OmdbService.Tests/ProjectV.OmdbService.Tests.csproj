<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Platforms>$(AppPlatforms)</Platforms>
    <Configurations>$(AppConfigurations)</Configurations>
    <OutputType>Library</OutputType>
    <TargetFrameworks>$(TestTargetFrameworks)</TargetFrameworks>
    <LangVersion>$(CSharpLangVersion)</LangVersion>
    <RootNamespace>ProjectV.OmdbService.Tests</RootNamespace>
    <IsPublishable>false</IsPublishable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <!--
    Core test stack (coverlet.collector, Microsoft.NET.Test.Sdk, xunit,
    xunit.runner.visualstudio, AwesomeAssertions, NSubstitute, WireMock.Net, …)
    is supplied by Sources/Tests/Directory.Build.props (no per-csproj
    PackageReference entries for the shared stack).
  -->

  <ItemGroup>
    <ProjectReference Include="$(SolutionDir)Libraries\ExternalServices\ProjectV.OmdbService\ProjectV.OmdbService.csproj" />
    <ProjectReference Include="$(SolutionDir)Tests\ProjectV.Tests.Shared\ProjectV.Tests.Shared.csproj" />
  </ItemGroup>

  <!--
    Copy ONLY the OMDb fixture subfolder to the test output's Fixtures/ root
    (FixtureLoader resolves at AppContext.BaseDirectory + "Fixtures").
    Per-provider scoping isolates failure surface so a misbehaving fixture
    does not cascade into other provider suites.
  -->
  <ItemGroup>
    <Content Include="$(SolutionDir)Tests\Fixtures\Omdb\**\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Fixtures\Omdb\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>

</Project>
