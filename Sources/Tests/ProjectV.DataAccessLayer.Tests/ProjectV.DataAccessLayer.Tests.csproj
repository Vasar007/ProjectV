<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Platforms>$(AppPlatforms)</Platforms>
    <Configurations>$(AppConfigurations)</Configurations>
    <OutputType>Library</OutputType>
    <TargetFrameworks>$(TestTargetFrameworks)</TargetFrameworks>
    <LangVersion>$(CSharpLangVersion)</LangVersion>
    <RootNamespace>ProjectV.DataAccessLayer.Tests</RootNamespace>
    <IsPublishable>false</IsPublishable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <!--
    Core test stack (coverlet.collector, Microsoft.NET.Test.Sdk, xunit,
    xunit.runner.visualstudio, AwesomeAssertions, NSubstitute, …) is supplied
    by Sources/Tests/Directory.Build.props per Decision D-03 (no per-csproj
    PackageReference entries for the shared stack). Testcontainers.PostgreSql,
    Microsoft.AspNetCore.Mvc.Testing, WireMock.Net and TimeProvider.Testing
    are included unconditionally from the same Directory.Build.props.

    Npgsql + EF Core are pulled in transitively via the ProjectV.DataAccessLayer
    project reference — no per-csproj PackageReference required.
  -->

  <ItemGroup>
    <ProjectReference Include="$(SolutionDir)Libraries\ProjectV.Configuration\ProjectV.Configuration.csproj" />
    <ProjectReference Include="$(SolutionDir)Libraries\ProjectV.DataAccessLayer\ProjectV.DataAccessLayer.csproj" />
    <ProjectReference Include="$(SolutionDir)Libraries\ProjectV.Models\ProjectV.Models.csproj" />
    <ProjectReference Include="$(SolutionDir)Tests\ProjectV.Tests.Shared\ProjectV.Tests.Shared.csproj" />
  </ItemGroup>

</Project>
